# IPC -> TaskLine integration (server-side)
# Local default TaskLine host path:
TASKLINE_URL=http://localhost:3002

# Backlink written into TaskLine metadata when IPC pushes/syncs projects.
IPC_URL=http://localhost:5173

# Browser deep-link base for "Open in TaskLine" links.
VITE_TASKLINE_APP_URL=http://localhost:3002

# Optional TaskLine compose vars when running --profile fullstack.
TASKLINE_SEED_ON_START=false
